{
  "name": "job-tracker",
  "version": "1.0.0",
  "description": "DevOps job application tracker with email integration",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "npm run start -w apps/api",
    "api:dev": "npm run start:dev -w apps/api",
    "web": "npm run dev -w apps/web",
    "db:migrate": "npm run migrate -w packages/database",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Trixxx12/job-tracker.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Trixxx12/job-tracker/issues"
  },
  "homepage": "https://github.com/Trixxx12/job-tracker#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "knex": "^3.1.0"
  }
}
